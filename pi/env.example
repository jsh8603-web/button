# Pi Relay Server Configuration
# Copy to .env and fill in your values

# Server port (default 7777)
PORT=7777

# Shared secret for Pi <-> Agent authentication (openssl rand -hex 32)
AGENT_SECRET=your-agent-secret-here

# PC network interface MAC address (ipconfig /all on Windows)
PC_MAC=00:00:00:00:00:00

# LAN broadcast address (usually your subnet ending in .255)
BROADCAST=192.168.219.255

# PC Agent LAN IP address
AGENT_HOST=192.168.219.100

# PC Agent port (default 9876)
AGENT_PORT=9876

# bcrypt hash of user PIN: node -e "require('bcrypt').hash('YOUR_PIN', 10).then(h => console.log(h))"
PIN_HASH=$2b$10$your-bcrypt-hash-here

# JWT signing secret for browser auth tokens (openssl rand -hex 32)
JWT_SECRET=your-random-hex-secret-here
