# Agent 서버 포트
PORT=9876

# PIN 인증 (web/.env.local의 PIN_HASH와 동일)
PIN_HASH=$2b$10$examplehashhere

# CORS 허용 오리진 (Vercel 배포 URL)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Heartbeat 전송 대상 (Vercel 배포 URL)
VERCEL_URL=https://your-app.vercel.app

# Agent↔Vercel 인증 토큰 (web/.env.local의 AGENT_SECRET과 동일)
AGENT_SECRET=your-random-agent-secret-here

# 프로젝트 디렉토리 경로 (프로젝트 목록 표시 대상)
PROJECTS_DIR=D:\projects

# 에디터 실행 명령 (VS Code: code, Cursor: cursor 등)
EDITOR_CMD=code

# bash 경로 (MSYS2/Git Bash — tmux 세션용)
BASH_PATH=C:\msys64\usr\bin\bash.exe

# Claude CLI 경로 (tmux 세션에서 자동 실행)
CLAUDE_BIN=claude

# 프로젝트 목록에서 제외할 디렉토리 (쉼표 구분)
IGNORE_DIRS=node_modules,screenshots
