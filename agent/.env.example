# Agent 서버 포트
PORT=9876

# PIN 인증 (web/.env.local의 PIN_HASH와 동일)
PIN_HASH=$2b$10$examplehashhere

# CORS 허용 오리진 (Vercel 배포 URL)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Heartbeat 전송 대상 (Vercel 배포 URL)
VERCEL_URL=https://your-app.vercel.app

# Agent↔Vercel 인증 토큰 (web/.env.local의 AGENT_SECRET과 동일)
AGENT_SECRET=your-random-agent-secret-here

# 프로젝트 디렉토리 경로 (프로젝트 목록 표시 대상)
PROJECTS_DIR=D:\projects

# 에디터 실행 명령 — 전체 경로 필수 (Agent가 PATH 없이 실행될 수 있음)
# 예: D:\projects\Antigravity\bin\antigravity.cmd
# 예: C:\Users\you\AppData\Local\Programs\Microsoft VS Code\bin\code.cmd
EDITOR_CMD=

# 에디터 창 제목에 표시되는 이름 (이전 프로젝트 창 닫기용)
# 예: Antigravity, Visual Studio Code, Cursor
EDITOR_TITLE=

# bash 경로 (MSYS2/Git Bash — tmux 세션용)
BASH_PATH=C:\msys64\usr\bin\bash.exe

# Claude CLI 경로 — 전체 경로 필수 (tmux 세션에서 자동 실행)
# 예: C:\Users\you\.local\bin\claude
CLAUDE_BIN=

# Claude 모델 (tmux 세션에서 사용)
CLAUDE_MODEL=opus

# 프로젝트 목록에서 제외할 디렉토리 (쉼표 구분)
IGNORE_DIRS=node_modules,screenshots

# --- 공유기 WOL (CAPTCHA 자동 로그인) ---

# Anthropic API key (Claude CLI용)
ANTHROPIC_API_KEY=sk-ant-api03-...

# 공유기 비밀번호 — 반드시 따옴표로 감싸기 (# 문자 때문)
ROUTER_PASSWORD="your-router-password"

# CapSolver API key (https://capsolver.com — CAPTCHA 풀이)
CAPTCHA_API_KEY=CAP-...

# OpenAI API key (GPT-4o mini — CAPTCHA 학습용 병렬 읽기)
OPENAI_API_KEY=sk-proj-...
