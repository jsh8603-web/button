# PIN 인증 (bcrypt hash 생성: node -e "require('bcrypt').hash('1234',10).then(console.log)")
PIN_HASH=$2b$10$examplehashhere
JWT_SECRET=your-random-32-char-secret-here

# Wake-on-LAN 대상 PC
PC_HOST=your-public-ip-or-ddns.duckdns.org
PC_MAC=AA:BB:CC:DD:EE:FF
WOL_PORT=9

# Agent 인증 (Agent의 AGENT_SECRET과 동일한 값)
AGENT_SECRET=your-random-agent-secret-here

# Supabase (https://supabase.com 프로젝트 Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
